```gitignore
# Dependencies
node_modules/

# Environment Variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime Data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Build Output
dist/
build/

# Temporary Files
tmp/
temp/

# OS Files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# Cache
.cache/
.eslintcache

# Package Manager
package-lock.json.bak
yarn.lock.bak
pnpm-lock.yaml.bak

# PM2
.pm2/

# Uploads (if generated at runtime)
uploads/
public/uploads/

# Database Files (if using SQLite)
*.sqlite
*.sqlite3

# Optional MongoDB Dump
dump/
```
